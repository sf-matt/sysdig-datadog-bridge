# Datadog API key
DD_API_KEY=

# Datadog log intake host — change to match your org's site:
#   US1: http-intake.logs.datadoghq.com
#   US3: http-intake.logs.us3.datadoghq.com
#   US5: http-intake.logs.us5.datadoghq.com
#   EU:  http-intake.logs.datadoghq.eu
#   AP1: http-intake.logs.ap1.datadoghq.com
DD_LOG_HOST=http-intake.logs.datadoghq.com

# Shared secret for the Sysdig webhook — set this in Sysdig as a custom header:
#   Authorization: Bearer <value>
WEBHOOK_TOKEN=
